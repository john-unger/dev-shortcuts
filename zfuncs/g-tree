#autoload

# Describes the entire dependency tree for the core module. This can be done for any project module.

function g-tree() {
    local module="${1:-}"

    if [[ -z "$module" ]]; then
        echo "Usage: g-tree <module>" >&2
        return 1
    fi

    echo -e "Running \e[34m./gradlew \e[32m:$module:dependencies\e[0m"
    ./gradlew ":$module:dependencies"
}
