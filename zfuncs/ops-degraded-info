#autoload

function ops-degraded-info() {
    local tenant="${1:-}"
    local frontend_pod

    if [[ -z "$tenant" ]]; then
        echo -e "Usage: ops-degraded-info \e[34m<tenant>\e[0m"
        echo "Example: \"qa\" or funds-qa"
        return 1
    fi

    echo -e "To be used within ops/tenants/. Describing pod of tenant: \e[34m $tenant \e[0m"
    frontend_pod="$(kubectl get -n "$tenant" pods -l app.kubernetes.io/name=frontend -o name)"
    kubectl describe -n "$tenant" "$frontend_pod" | grep '^Events:' -A1000
}

