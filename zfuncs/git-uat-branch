#autoload

function git-uat-branch() {
    local branch_name="${1:-}"

    if [[ -z "$branch_name" ]]; then
        echo -e "Usage: git-uat-branch \e[34m<git branch_name>\e[0m"
        return 1
    fi

    echo -e "Pulling in origin of \e[34m $branch_name \e[0m..."

    git fetch origin
    git merge --no-edit origin/"$branch_name"

}
